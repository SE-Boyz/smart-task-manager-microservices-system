{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": ["package.json", "package-lock.json", "node_modules"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  }
}
