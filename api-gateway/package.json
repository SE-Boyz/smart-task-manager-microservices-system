{
    "name": "api-gateway",
    "version": "1.0.0",
    "description": "API gateway for Smart Task Manager microservices",
    "type": "module",
    "main": "src/server.ts",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
        "build": "tsc",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests"
    },
    "dependencies": {
        "axios": "^1.8.4",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "helmet": "^8.1.0",
        "mongodb": "^6.16.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.1",
        "@types/node": "^24.5.2",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "cross-env": "^10.1.0",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2"
    }
}
